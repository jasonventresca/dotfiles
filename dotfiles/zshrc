# zsh-specific configuration, targeting the zsh that ships with macOS.
# Shared aliases/functions/exports live in shell_common.sh (also used by bashrc).

# --- Oh My Zsh (if installed; see setup/dev_tools.sh) ---
if [[ -d $HOME/.oh-my-zsh ]]; then
    export ZSH="$HOME/.oh-my-zsh"
    ZSH_THEME=""  # the prompt is handled by starship, at the bottom of this file
    plugins=(git)
    source $ZSH/oh-my-zsh.sh
else
    autoload -Uz compinit && compinit
fi

# --- history (mirrors the bashrc settings) ---
HISTFILE=$HOME/.zsh_history
HISTSIZE=1000
SAVEHIST=2000
setopt HIST_IGNORE_DUPS   # like bash HISTCONTROL=ignoredups
setopt HIST_IGNORE_SPACE  # like bash HISTCONTROL=ignorespace
setopt APPEND_HISTORY     # like bash shopt -s histappend
setopt HIST_VERIFY        # like bash shopt -s histverify

# --- bash-like behavior ---
setopt NO_NOMATCH             # pass unmatched globs through instead of erroring
setopt INTERACTIVE_COMMENTS   # allow '#' comments on the command line

# --- vi-mode keybindings (mirrors inputrc, which only applies to bash/readline) ---
bindkey -v
bindkey -M viins 'jj' vi-cmd-mode
bindkey -M viins 'jrr' history-incremental-search-backward
bindkey -M viins '^R' history-incremental-search-backward
bindkey -M viins '^L' clear-screen
bindkey -M vicmd '^L' clear-screen
# 'jae' expands aliases inline, like readline's alias-expand-line
zle -C alias-expand complete-word _generic
zstyle ':completion:alias-expand:*' completer _expand_alias
bindkey -M viins 'jae' alias-expand

# shared aliases + functions (sourced after Oh My Zsh, so ours take precedence)
source $HOME/dotfiles.jason_ventresca/dotfiles/shell_common.sh

# --- prompt + line-editor niceties ---
# https://medium.com/@yi.cheng/setting-up-the-pretty-mac-terminal-in-2026-ghostty-starship-catppuccin-0420189ad43f
BREW_SHARE="${HOMEBREW_PREFIX:-/opt/homebrew}/share"
[[ -f $BREW_SHARE/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
    source $BREW_SHARE/zsh-autosuggestions/zsh-autosuggestions.zsh
command -v starship >/dev/null && eval "$(starship init zsh)"
# zsh-syntax-highlighting must be sourced last (per its README)
[[ -f $BREW_SHARE/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
    source $BREW_SHARE/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
